# =============================================================================
# Agentic Decision System — Environment Configuration
# =============================================================================
# Copy this file to .env and edit as needed:
#   cp .env.example .env
#
# This is a local MVP beta candidate. It is not production-ready.
# No real API keys are required — the fake provider works offline.
# =============================================================================

# --- Core Settings ---
# Data directory for all persistent state (chroma, workspaces, providers, etc.)
DECISION_SYSTEM_DATA_DIR=.decision_system

# Security mode: "demo" (default) or "governed"
# demo = relaxed permissions, no approval required
# governed = full RBAC, approval gates, audit enforcement
DECISION_SYSTEM_SECURITY_MODE=demo

# Enable the unsafe code execution node (dangerous, use only in isolated env)
# WARNING: This node runs arbitrary Python code from workflow nodes.
DECISION_SYSTEM_ENABLE_UNSAFE_CODE_NODE=false

# Enable local dev connector paths (allows importing from arbitrary local dirs)
DECISION_SYSTEM_ENABLE_LOCAL_DEV_CONNECTOR_PATHS=false

# --- Provider Configuration ---
# The fake provider is the default and requires no API keys.
# Set DECISION_PROVIDER to "fake", "openai", "anthropic", or "ollama".
DECISION_PROVIDER=fake

# Optional: OpenAI (requires API key)
OPENAI_API_KEY=
# Optional: Anthropic (requires API key)
ANTHROPIC_API_KEY=
# Optional: Local OpenAI-compatible server
LOCAL_OPENAI_API_KEY=
LOCAL_OPENAI_BASE_URL=

# Optional: Ollama (local models)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=
OLLAMA_TEMPERATURE=0
OLLAMA_MAX_TOKENS=2048
OLLAMA_TIMEOUT_SECONDS=60

# Optional: NVIDIA NIM
NVIDIA_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=
NVIDIA_TEMPERATURE=0
NVIDIA_TOP_P=0.95
NVIDIA_MAX_TOKENS=4096
NVIDIA_REASONING_ENABLED=false
NVIDIA_REASONING_EFFORT=medium

# --- Connector Configuration ---
# GitHub personal access token (for authenticated API access / higher rate limits)
GITHUB_TOKEN=
# Notion integration token (planned for future milestone)
NOTION_API_KEY=
# Google Drive access token (planned for future milestone)
GOOGLE_DRIVE_TOKEN=

# --- Deprecated / Legacy Settings ---
# These are preserved for compatibility but will be removed in a future version.
DECISION_DOCS_DIR=company_docs
DECISION_STORE_DIR=.decision_system/chroma
DECISION_COLLECTION=decision_chunks
